{
  "manifest_version": 3,
  "name": "link-pilot",
  "version": "0.1.0",
  "description": "로컬 서버 + SQLite 북마크 저장",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1:4312/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "link-pilot",
    "default_popup": "popup.html"
  },
  "commands": {
    "save-bookmark": {
      "description": "현재 페이지를 로컬 북마크로 저장"
    }
  }
}
